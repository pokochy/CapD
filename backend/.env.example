# ─────────────────────────────────────────
#  Vulnerability Scanner - Backend .env
# ─────────────────────────────────────────

# 앱 기본 설정
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# SQLite DB 경로 (파일 기반 경량 DB)
DATABASE_URL=sqlite:///./scanner.db

# 스캔 엔진 설정
SCAN_TIMEOUT=30               # 단일 요청 타임아웃 (초)
SCAN_MAX_DEPTH=3              # 크롤링 최대 깊이
SCAN_CONCURRENCY=5            # 동시 요청 수
SCAN_DELAY=0.5                # 요청 간 딜레이 (초) - WAF 우회용

# HTTP 클라이언트
USER_AGENT=Mozilla/5.0 (compatible; VulnScanner/1.0)
FOLLOW_REDIRECTS=true
MAX_REDIRECTS=5
VERIFY_SSL=false              # 자체 서명 인증서 허용

# CORS (프론트엔드 연동 시)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 로깅
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/scanner.log
