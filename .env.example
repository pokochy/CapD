# ── 서버 설정 ────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ── 데이터베이스 ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./scanner.db

# ── 스캔 설정 ─────────────────────────────────────────────────────────────────
SCAN_TIMEOUT=30
SCAN_MAX_DEPTH=3
SCAN_CONCURRENCY=5
SCAN_DELAY=0.5
USER_AGENT=VulnScanner/2.0
VERIFY_SSL=false
FOLLOW_REDIRECTS=true
MAX_REDIRECTS=5

# ── CORS (프론트엔드 연동 시) ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── 로그 ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log

# ── 디버그 ───────────────────────────────────────────────────────────────────
DEBUG=false
